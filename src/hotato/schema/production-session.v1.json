{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hotato.dev/schema/production-session.v1.json",
  "title": "Hotato finalized production session manifest, version 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "session_id", "status", "event_count", "duplicate_count",
    "conflict_count", "out_of_order_count", "unsequenced_count",
    "highest_sequence", "lifecycle", "evidence", "required_evidence_lanes", "payload_storage", "stored_event_log_sha256", "finalized_at",
    "finalization_reason"
  ],
  "properties": {
    "schema": {"const": "hotato.production-session.v1"},
    "session_id": {"type": "string", "minLength": 1, "maxLength": 500},
    "status": {"enum": ["OPEN", "QUIESCENT", "COMPLETE", "DEGRADED", "EXPIRED", "DELETED"]},
    "event_count": {"type": "integer", "minimum": 0},
    "duplicate_count": {"type": "integer", "minimum": 0},
    "conflict_count": {"type": "integer", "minimum": 0},
    "out_of_order_count": {"type": "integer", "minimum": 0},
    "unsequenced_count": {"type": "integer", "minimum": 0},
    "highest_sequence": {"type": ["integer", "null"], "minimum": 0},
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_started_events", "session_ended_events", "unambiguous"],
      "properties": {
        "session_started_events": {"type": "integer", "minimum": 0},
        "session_ended_events": {"type": "integer", "minimum": 0},
        "unambiguous": {"type": "boolean"}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["participant_audio", "transcript", "model_trace", "tool_calls", "backend_state"],
      "properties": {
        "participant_audio": {"$ref": "#/$defs/lane"},
        "transcript": {"$ref": "#/$defs/lane"},
        "model_trace": {"$ref": "#/$defs/lane"},
        "tool_calls": {"$ref": "#/$defs/lane"},
        "backend_state": {"$ref": "#/$defs/lane"}
      }
    },
    "required_evidence_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["participant_audio", "transcript", "model_trace", "tool_calls", "backend_state"]}
    },
    "payload_storage": {"enum": ["redacted", "unredacted", "mixed"]},
    "stored_event_log_sha256": {"$ref": "#/$defs/digest"},
    "finalized_at": {"type": ["number", "null"]},
    "finalization_reason": {"type": ["string", "null"]}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["availability", "authority", "eligible_for_execution_claim", "event_ids"],
      "properties": {
        "availability": {"enum": ["missing", "available", "unavailable", "unsupported", "deleted"]},
        "authority": {"enum": ["unavailable", "submitted", "adapter_reported", "provider_export", "signed_attestation", "measured"]},
        "eligible_for_execution_claim": {"type": "boolean"},
        "event_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      }
    }
  }
}
