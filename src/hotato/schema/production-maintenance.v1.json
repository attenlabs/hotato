{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hotato.dev/schema/production-maintenance.v1.json",
  "title": "Hotato production maintenance policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "required_lanes", "alert_rules"],
  "properties": {
    "schema": {"const": "hotato.production-maintenance.v1"},
    "interval_seconds": {"type": "number", "minimum": 0.1, "maximum": 86400},
    "quiescence_seconds": {"type": "number", "minimum": 0, "maximum": 86400},
    "required_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["participant_audio", "transcript", "model_trace", "tool_calls", "backend_state"]
      }
    },
    "alert_rules": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "condition"],
        "properties": {
          "id": {"type": "string", "minLength": 1, "maxLength": 200},
          "condition": {
            "enum": ["degraded", "missing_audio", "missing_tool_evidence", "incomplete_evidence", "conflict", "out_of_order", "unsequenced"]
          }
        }
      }
    },
    "retention_seconds": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 315360000
    }
  }
}
