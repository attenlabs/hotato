{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hotato.dev/schema/counterexample-oracle.v1.json",
  "title": "Hotato deterministic counterexample oracle",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "version", "authority", "ci_gate_eligible", "target", "observation_scope"],
  "properties": {
    "kind": {"const": "hotato.counterexample-oracle.v1"},
    "version": {"const": 1},
    "authority": {"const": "deterministic"},
    "ci_gate_eligible": {"const": true},
    "target": {"$ref": "#/definitions/target"},
    "observation_scope": {"$ref": "#/definitions/observation_scope"}
  },
  "definitions": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "nonnegative_integer": {"type": "integer", "minimum": 0},
    "dimension": {
      "type": ["string", "null"],
      "enum": ["outcome", "policy", "conversation", "speech", "reliability", null]
    },
    "assertion_kind": {
      "enum": [
        "phrase", "pii", "policy", "tool_call", "outcome", "tool_result",
        "tool_error", "state", "state_change", "handoff", "dtmf",
        "termination", "latency", "entity_accuracy", "sequence", "count"
      ]
    },
    "count_bounds": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["observed", "expected", "relation"],
          "properties": {
            "observed": {"$ref": "#/definitions/nonnegative_integer"},
            "expected": {"$ref": "#/definitions/nonnegative_integer"},
            "relation": {"const": "equal"}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["observed", "min", "max"],
          "properties": {
            "observed": {"$ref": "#/definitions/nonnegative_integer"},
            "min": {"type": ["integer", "null"], "minimum": 0},
            "max": {"type": ["integer", "null"], "minimum": 0}
          },
          "not": {"properties": {"min": {"const": null}, "max": {"const": null}}}
        }
      ]
    },
    "phrase_witness": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "mode", "matches"],
      "properties": {
        "type": {"const": "phrase-failure"},
        "mode": {"enum": ["forbidden-present", "required-missing"]},
        "matches": {"$ref": "#/definitions/nonnegative_integer"}
      }
    },
    "pii_witness": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "detector_roles", "hits", "hit_anchors"],
      "properties": {
        "type": {"const": "pii-failure"},
        "detector_roles": {
          "type": "array",
          "items": {
            "type": "array", "minItems": 2, "maxItems": 2,
            "items": [
              {"enum": ["ssn", "card_luhn", "email", "phone"]},
              {"type": ["string", "null"]}
            ],
            "additionalItems": false
          }
        },
        "hits": {"$ref": "#/definitions/nonnegative_integer"},
        "hit_anchors": {
          "type": "array",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["detector", "role", "turn_text_digest"],
            "properties": {
              "detector": {"enum": ["ssn", "card_luhn", "email", "phone"]},
              "role": {"type": ["string", "null"]},
              "turn_text_digest": {
                "oneOf": [{"$ref": "#/definitions/digest"}, {"type": "null"}]
              }
            }
          }
        }
      }
    },
    "policy_witness": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "violations", "pack"],
      "properties": {
        "type": {"const": "policy-failure"},
        "violations": {
          "type": "array",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["rule", "type"],
            "properties": {
              "rule": {"type": "string"},
              "type": {"enum": ["banned", "required_disclosure_missing"]}
            }
          }
        },
        "pack": {
          "type": "object", "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": {"type": ["string", "null"]},
            "version": {"type": ["integer", "string", "null"]}
          }
        }
      }
    },
    "tool_call_witness": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "named_matches"],
      "properties": {
        "type": {"const": "tool_call-failure"},
        "named_matches": {"$ref": "#/definitions/nonnegative_integer"},
        "count": {"$ref": "#/definitions/count_bounds"},
        "order_prefix": {"$ref": "#/definitions/nonnegative_integer"},
        "order_steps": {"type": "integer", "minimum": 1},
        "never_before": {
          "type": "object", "additionalProperties": false,
          "required": ["offenders", "until_present"],
          "properties": {
            "offenders": {"$ref": "#/definitions/nonnegative_integer"},
            "until_present": {"type": "boolean"}
          }
        }
      },
      "dependencies": {"order_prefix": ["order_steps"], "order_steps": ["order_prefix"]}
    },
    "outcome_witness": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "mode", "met", "of", "predicates"],
      "properties": {
        "type": {"const": "outcome-failure"}, "mode": {"enum": ["all_of", "any_of"]},
        "met": {"$ref": "#/definitions/nonnegative_integer"}, "of": {"type": "integer", "minimum": 1},
        "predicates": {
          "type": "array", "minItems": 1,
          "items": {"$ref": "#/definitions/outcome_predicate"}
        }
      }
    },
    "outcome_predicate": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["index", "kind", "matches"],
          "properties": {
            "index": {"$ref": "#/definitions/nonnegative_integer"},
            "kind": {"const": "tool_called"},
            "matches": {"$ref": "#/definitions/nonnegative_integer"}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["index", "kind", "matches", "turn_text_digests"],
          "properties": {
            "index": {"$ref": "#/definitions/nonnegative_integer"},
            "kind": {"const": "phrase"},
            "matches": {"$ref": "#/definitions/nonnegative_integer"},
            "turn_text_digests": {"type": "array", "items": {"$ref": "#/definitions/digest"}}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["index", "kind", "present"],
          "properties": {
            "index": {"$ref": "#/definitions/nonnegative_integer"},
            "kind": {"const": "field_present"},
            "present": {"const": false}
          }
        }
      ]
    },
    "tool_result_witness": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "calls", "matching_results"],
      "properties": {
        "type": {"const": "tool_result-failure"},
        "calls": {"$ref": "#/definitions/nonnegative_integer"},
        "matching_results": {"$ref": "#/definitions/nonnegative_integer"}
      }
    },
    "tool_error_witness": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "mode", "matching_errors"],
      "properties": {
        "type": {"const": "tool_error-failure"},
        "mode": {"enum": ["error-forbidden", "error-required"]},
        "matching_errors": {"$ref": "#/definitions/nonnegative_integer"}
      }
    },
    "state_witness": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["type", "record"],
          "properties": {"type": {"const": "state-failure"}, "record": {"const": "absent"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["type", "record", "mismatched"],
          "properties": {
            "type": {"const": "state-failure"}, "record": {"const": "present"},
            "mismatched": {
              "type": "array",
              "items": {
                "type": "object", "additionalProperties": false,
                "required": ["path", "observed"],
                "properties": {
                  "path": {"type": "string", "minLength": 1},
                  "observed": {"oneOf": [{"$ref": "#/definitions/digest"}, {"type": "null"}]}
                }
              }
            }
          }
        }
      ]
    },
    "state_change_witness": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "before_present", "after_present", "checks", "before_value", "after_value"],
      "properties": {
        "type": {"const": "state_change-failure"},
        "before_present": {"type": "boolean"}, "after_present": {"type": "boolean"},
        "checks": {
          "type": "array", "uniqueItems": true,
          "items": {"enum": ["from-mismatch", "to-mismatch", "unchanged"]}
        },
        "before_value": {"oneOf": [{"$ref": "#/definitions/digest"}, {"type": "null"}]},
        "after_value": {"oneOf": [{"$ref": "#/definitions/digest"}, {"type": "null"}]}
      }
    },
    "handoff_witness": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "mode", "matches"],
      "properties": {
        "type": {"const": "handoff-failure"}, "mode": {"enum": ["forbidden", "required"]},
        "matches": {"$ref": "#/definitions/nonnegative_integer"}
      }
    },
    "dtmf_witness": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "mode", "contains", "stream_digest"],
      "properties": {
        "type": {"const": "dtmf-failure"}, "mode": {"enum": ["forbidden", "required"]},
        "contains": {"type": "boolean"}, "stream_digest": {"$ref": "#/definitions/digest"}
      }
    },
    "termination_witness": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "mode", "matches"],
      "properties": {
        "type": {"const": "termination-failure"}, "mode": {"enum": ["forbidden", "required"]},
        "matches": {"$ref": "#/definitions/nonnegative_integer"}
      }
    },
    "latency_witness": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "measured", "measured_ms"],
      "properties": {
        "type": {"const": "latency-failure"}, "measured": {"type": "null"},
        "measured_ms": {"type": "number", "minimum": 0}
      }
    },
    "entity_accuracy_witness": {
      "type": "object", "additionalProperties": false,
      "required": [
        "type", "met", "of", "require", "mismatched_keys", "observed_value_digests"
      ],
      "properties": {
        "type": {"const": "entity_accuracy-failure"},
        "met": {"$ref": "#/definitions/nonnegative_integer"},
        "of": {"type": "integer", "minimum": 1}, "require": {"enum": ["all", "any"]},
        "mismatched_keys": {
          "type": "array", "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "observed_value_digests": {
          "type": "object", "additionalProperties": {"$ref": "#/definitions/digest"}
        }
      }
    },
    "sequence_witness": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "matched_prefix", "steps"],
      "properties": {
        "type": {"const": "sequence-failure"},
        "matched_prefix": {"$ref": "#/definitions/nonnegative_integer"},
        "steps": {"type": "integer", "minimum": 1}
      }
    },
    "count_witness": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "count"],
      "properties": {"type": {"const": "count-failure"}, "count": {"$ref": "#/definitions/count_bounds"}}
    },
    "typed_witness": {
      "oneOf": [
        {"$ref": "#/definitions/phrase_witness"}, {"$ref": "#/definitions/pii_witness"},
        {"$ref": "#/definitions/policy_witness"}, {"$ref": "#/definitions/tool_call_witness"},
        {"$ref": "#/definitions/outcome_witness"}, {"$ref": "#/definitions/tool_result_witness"},
        {"$ref": "#/definitions/tool_error_witness"}, {"$ref": "#/definitions/state_witness"},
        {"$ref": "#/definitions/state_change_witness"}, {"$ref": "#/definitions/handoff_witness"},
        {"$ref": "#/definitions/dtmf_witness"}, {"$ref": "#/definitions/termination_witness"},
        {"$ref": "#/definitions/latency_witness"}, {"$ref": "#/definitions/entity_accuracy_witness"},
        {"$ref": "#/definitions/sequence_witness"}, {"$ref": "#/definitions/count_witness"}
      ]
    },
    "target": {
      "type": "object", "additionalProperties": false,
      "required": [
        "test_id", "assertion_digest", "assertion_id", "kind", "dimension",
        "authority", "required_status", "witness", "fingerprint"
      ],
      "properties": {
        "test_id": {"type": "string", "minLength": 1},
        "assertion_digest": {"$ref": "#/definitions/digest"},
        "assertion_id": {"type": "string", "minLength": 1},
        "kind": {"$ref": "#/definitions/assertion_kind"},
        "dimension": {"$ref": "#/definitions/dimension"},
        "authority": {"const": "deterministic"}, "required_status": {"const": "FAIL"},
        "witness": {"$ref": "#/definitions/typed_witness"},
        "fingerprint": {"$ref": "#/definitions/digest"}
      },
      "allOf": [
        {"if": {"properties": {"kind": {"const": "phrase"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/phrase_witness"}}}},
        {"if": {"properties": {"kind": {"const": "pii"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/pii_witness"}}}},
        {"if": {"properties": {"kind": {"const": "policy"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/policy_witness"}}}},
        {"if": {"properties": {"kind": {"const": "tool_call"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/tool_call_witness"}}}},
        {"if": {"properties": {"kind": {"const": "outcome"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/outcome_witness"}}}},
        {"if": {"properties": {"kind": {"const": "tool_result"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/tool_result_witness"}}}},
        {"if": {"properties": {"kind": {"const": "tool_error"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/tool_error_witness"}}}},
        {"if": {"properties": {"kind": {"const": "state"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/state_witness"}}}},
        {"if": {"properties": {"kind": {"const": "state_change"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/state_change_witness"}}}},
        {"if": {"properties": {"kind": {"const": "handoff"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/handoff_witness"}}}},
        {"if": {"properties": {"kind": {"const": "dtmf"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/dtmf_witness"}}}},
        {"if": {"properties": {"kind": {"const": "termination"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/termination_witness"}}}},
        {"if": {"properties": {"kind": {"const": "latency"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/latency_witness"}}}},
        {"if": {"properties": {"kind": {"const": "entity_accuracy"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/entity_accuracy_witness"}}}},
        {"if": {"properties": {"kind": {"const": "sequence"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/sequence_witness"}}}},
        {"if": {"properties": {"kind": {"const": "count"}}}, "then": {"properties": {"witness": {"$ref": "#/definitions/count_witness"}}}}
      ]
    },
    "observation_scope": {
      "type": "object", "additionalProperties": false,
      "required": ["frozen_components", "rule", "minimum_caller_turns", "transforms"],
      "properties": {
        "frozen_components": {
          "type": "array", "uniqueItems": true,
          "items": {"enum": ["script", "tools", "state", "handoff", "termination"]}
        },
        "rule": {
          "const": "candidate is a complete schema-valid scripted session and must reproduce the exact typed failure fingerprint"
        },
        "minimum_caller_turns": {"const": 1},
        "transforms": {"const": "deletion-only"}
      }
    }
  }
}
