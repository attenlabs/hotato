{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hotato.dev/schema/load-plan.v2.json",
  "title": "Hotato evidence-preserving load plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "call", "stages"],
  "allOf": [
    {
      "if": {
        "properties": {
          "call": {
            "type": "object",
            "required": ["provider"],
            "properties": {"provider": {"enum": ["twilio", "vapi", "retell"]}}
          }
        }
      },
      "then": {
        "required": ["safety"],
        "properties": {
          "safety": {
            "required": ["estimated_cost_per_call_usd", "max_estimated_cost_usd", "allowed_destinations"],
            "properties": {
              "estimated_cost_per_call_usd": {"type": "number", "exclusiveMinimum": 0},
              "max_estimated_cost_usd": {"type": "number", "exclusiveMinimum": 0},
              "allowed_destinations": {"type": "array", "minItems": 1}
            }
          }
        }
      }
    }
  ],
  "properties": {
    "schema": {"const": "hotato.load-plan.v2"},
    "id": {"type": "string", "minLength": 1, "maxLength": 200},
    "call": {"type": "object"},
    "terminal_timeout_seconds": {"type": "number", "exclusiveMinimum": 0, "maximum": 86400},
    "poll_seconds": {"type": "number", "minimum": 0.001, "maximum": 300},
    "stages": {
      "type": "array", "minItems": 1, "maxItems": 100,
      "items": {
        "oneOf": [
          {
            "type": "object", "additionalProperties": false,
            "required": ["name", "phase", "model", "concurrency", "calls"],
            "properties": {
              "name": {"type": "string", "minLength": 1, "maxLength": 100},
              "phase": {"enum": ["warmup", "ramp", "stress", "spike", "soak", "recovery"]},
              "model": {"const": "closed"},
              "concurrency": {"type": "integer", "minimum": 1, "maximum": 1000},
              "calls": {"type": "integer", "minimum": 1, "maximum": 100000}
            }
          },
          {
            "type": "object", "additionalProperties": false,
            "required": ["name", "phase", "model", "arrival_rate_per_second", "duration_seconds", "max_in_flight"],
            "properties": {
              "name": {"type": "string", "minLength": 1, "maxLength": 100},
              "phase": {"enum": ["warmup", "ramp", "stress", "spike", "soak", "recovery"]},
              "model": {"const": "open"},
              "arrival_rate_per_second": {"type": "number", "minimum": 0.001, "maximum": 100000},
              "duration_seconds": {"type": "number", "minimum": 0.001, "maximum": 604800},
              "max_in_flight": {"type": "integer", "minimum": 1, "maximum": 1000}
              ,"calls": {"type": "integer", "minimum": 1, "maximum": 100000, "readOnly": true}
            }
          }
        ]
      }
    },
    "safety": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "max_calls": {"type": "integer", "minimum": 1, "maximum": 100000},
        "estimated_cost_per_call_usd": {"type": "number", "minimum": 0},
        "max_estimated_cost_usd": {"type": "number", "minimum": 0},
        "estimated_plan_cost_usd": {"type": "number", "minimum": 0, "readOnly": true},
        "allowed_destinations": {"type": "array", "maxItems": 1000, "items": {"type": "string", "minLength": 1}},
        "stop_file": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "faults": {
      "type": "array", "maxItems": 1000,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["stage", "after_call", "kind", "duration_calls"],
        "properties": {
          "stage": {"type": "string", "minLength": 1},
          "after_call": {"type": "integer", "minimum": 0, "maximum": 100000},
          "kind": {"type": "string", "minLength": 1, "maxLength": 100},
          "duration_calls": {"type": "integer", "minimum": 1, "maximum": 100000}
        }
      }
    },
    "slos": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "max_create_error_rate": {"type": "number", "minimum": 0},
        "max_incomplete_rate": {"type": "number", "minimum": 0},
        "min_lifecycle_completion_rate": {"type": "number", "minimum": 0},
        "min_evidence_complete_rate": {"type": "number", "minimum": 0},
        "max_p95_terminal_seconds": {"type": "number", "minimum": 0},
        "max_dropped_start_rate": {"type": "number", "minimum": 0},
        "max_p95_scheduling_delay_seconds": {"type": "number", "minimum": 0},
        "max_recovery_seconds": {"type": "number", "minimum": 0}
      }
    }
  }
}
