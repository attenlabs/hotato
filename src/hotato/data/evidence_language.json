      "required_state": "runner_attested",
      "max_tier": 3,
      "surface": "card_headline"
    },
    "PAIRED IMPROVED (RECAPTURE OPERATOR-ASSERTED)": {
      "machine_field": "capture_origin",
      "required_state": "operator_asserted",
      "max_tier": 3,
      "surface": "card_headline"
    },
    "PAIRED (OPERATOR-ASSERTED)": {
      "machine_field": "capture_origin",
      "required_state": "operator_asserted",
