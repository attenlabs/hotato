def run_hotato_ingest(event_path: Path, report_html: Path) -> dict:
    """Delegate the whole vendor interaction to ``hotato ingest`` (READ-ONLY).

    ingest parses the saved payload for the call id / recording locator, fetches
    the dual-channel recording with a GET, and scans it offline for candidate
    moments. It never mutates platform config and never labels intent; this
    worker adds no vendor call of its own. Returns the parsed candidate result
    (discovery only, never a verdict)."""
    proc = subprocess.run(
        [
            "hotato", "ingest",
            "--stack", "{{STACK}}",
            "--event", str(event_path),
            "--format", "json",
            "--out", str(report_html),
        ],
        capture_output=True,
        text=True,
        timeout=600,
    )
    if proc.returncode != 0:
        # exit 2 = a mono / not-scorable recording, or a fetch / parse problem.
        # That is a discovery outcome, not a verdict; surface it and move on.
        raise HTTPException(
            status_code=422,
            detail="hotato ingest could not scan this call: "
            + proc.stderr.strip()[-400:],
        )
    try:
        return json.loads(proc.stdout or "{}")
    except json.JSONDecodeError:
        return {"total_candidates": 0, "candidates": []}


def notify_slack(result: dict, report_html: Path) -> None:
    """Post the candidate summary to Slack, only when SLACK_WEBHOOK_URL is set.

    Discovery language only: candidate moments, never a verdict and never an
    intent label."""
    if not SLACK_WEBHOOK_URL:
        return
    n = int(result.get("total_candidates", 0) or 0)
    if n == 0:
        return
    source = str(result.get("source", "a call"))
    text = (
        "hotato found " + str(n) + " candidate turn-taking moment(s) in "
        + source + ". These are timing candidates to review, not verdicts. "
        "Promote a real one with `hotato fixture promote`.\nreport: "
        + str(report_html)
    )
    body = json.dumps({"text": text}).encode("utf-8")
    req = urllib.request.Request(
        SLACK_WEBHOOK_URL,
        data=body,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        urllib.request.urlopen(req, timeout=15).read()
    except Exception:
        # A notification is best-effort; a Slack outage never fails the webhook.
        pass


def notify_github(result: dict, report_html: Path) -> None:
    """Optional GitHub notification. Default OFF; opens NOTHING unless you
    explicitly opt in with HOTATO_GITHUB_CREATE_ISSUES=1 plus GITHUB_REPOSITORY
    and GITHUB_TOKEN. With only HOTATO_GITHUB_NOTIFY=1 it logs a pointer and
    creates nothing -- the worker never auto-files issues from candidates."""
    if not GITHUB_NOTIFY:
        return
    n = int(result.get("total_candidates", 0) or 0)
    if n == 0:
        return
    repo = os.environ.get("GITHUB_REPOSITORY", "")
    token = os.environ.get("GITHUB_TOKEN", "")
    if not (GITHUB_CREATE_ISSUES and repo and token):
        # Default path: notify by log only. No issue is created.
        print(
            "[hotato] " + str(n) + " candidate moment(s); review "
            + str(report_html) + ". Set HOTATO_GITHUB_CREATE_ISSUES=1 (+ repo / "
            "token) to open an issue."
        )
        return
    title = "hotato: " + str(n) + " candidate turn-taking moment(s) to review"
    body = (
        "hotato surfaced " + str(n) + " candidate moment(s). These are timing "
        "candidates, not verdicts. Review " + str(report_html)
        + " and promote a real one with `hotato fixture promote`."
    )
    payload = json.dumps({"title": title, "body": body}).encode("utf-8")
    req = urllib.request.Request(
        "https://api.github.com/repos/" + repo + "/issues",
        data=payload,
        headers={
            "Authorization": "Bearer " + token,
            "Accept": "application/vnd.github+json",
            "Content-Type": "application/json",
        },
        method="POST",
    )
    try:
        urllib.request.urlopen(req, timeout=15).read()
    except Exception:
        pass


@app.post("/webhook")
async def handle_webhook(request: Request):
    # Read the raw bytes first (the secret check needs them), bounded so an
    # oversized or chunked-infinite body cannot be buffered into memory before
    # VERIFY ever runs, then VERIFY. No parse, fetch, or scan happens until the
    # secret check passes.
    raw_body = await read_bounded_body(request)
    verify_webhook(request, raw_body)

    payload = parse_payload(raw_body)
    # Only act on the call-ended event that carries a finished recording.
    if not is_target_event(payload):
        return Response(status_code=200)

    REPORT_DIR.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile(
        "wb", suffix=".json", dir=str(REPORT_DIR), delete=False
    ) as fh:
        fh.write(raw_body)
        event_path = Path(fh.name)
    report_html = REPORT_DIR / (event_path.stem + ".html")

    result = run_hotato_ingest(event_path, report_html)
    notify_slack(result, report_html)
    notify_github(result, report_html)

    return {
        "ok": True,
        "candidates": int(result.get("total_candidates", 0) or 0),
        "report": str(report_html),
    }


