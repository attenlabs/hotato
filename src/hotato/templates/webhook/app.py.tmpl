# Hard cap on an accepted webhook body, in bytes. Webhook payloads are JSON (or
# form-encoded) call metadata, not audio, so this is generous for any real
# payload while still bounding memory use from an oversized or infinite
# (chunked-transfer-encoding, which never declares Content-Length) POST body.
# Override with HOTATO_MAX_BODY_BYTES if a stack's payload legitimately needs
# more.
MAX_BODY_BYTES = int(os.environ.get("HOTATO_MAX_BODY_BYTES", str(2 * 1024 * 1024)))

# Optional Slack summary: set SLACK_WEBHOOK_URL to post one message per call
# that surfaced candidate moments. Unset -> no Slack call.
