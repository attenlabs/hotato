# Optional GitHub notification. OFF by default. It NEVER opens an issue unless
# you explicitly set HOTATO_GITHUB_CREATE_ISSUES=1 together with GITHUB_REPOSITORY
# and GITHUB_TOKEN; with only HOTATO_GITHUB_NOTIFY=1 it logs a one-line pointer
# and opens nothing.
GITHUB_NOTIFY = os.environ.get("HOTATO_GITHUB_NOTIFY", "") not in ("", "0", "false")
GITHUB_CREATE_ISSUES = os.environ.get("HOTATO_GITHUB_CREATE_ISSUES", "") not in ("", "0", "false")


async def read_bounded_body(request: Request) -> bytes:
    """Read the request body with a hard size cap, BEFORE verify/parse/scan.

    Starlette's ``Request.body()`` has no built-in size limit: it loops on the
    ASGI receive channel and buffers every chunk into memory until the body is
    exhausted, no matter how large it is, and a chunked-transfer-encoding
    request never declares a Content-Length at all so a length check alone
    would not catch it. This reads the same bytes ``Request.body()`` would,
    but (1) rejects early on a declared oversized Content-Length, and (2)
    streams the body and re-checks the running total after every chunk, so an
    oversized body -- declared or chunked -- is rejected with a clean 413
    before a single byte reaches ``verify_webhook``, the parser, or disk."""
    declared = request.headers.get("content-length")
    if declared is not None:
        try:
            declared_size = int(declared)
        except ValueError:
            declared_size = None
        if declared_size is not None and declared_size > MAX_BODY_BYTES:
            raise HTTPException(status_code=413, detail="request body too large")
    chunks = []
    total = 0
    async for chunk in request.stream():
        total += len(chunk)
        if total > MAX_BODY_BYTES:
            raise HTTPException(status_code=413, detail="request body too large")
        chunks.append(chunk)
    return b"".join(chunks)


