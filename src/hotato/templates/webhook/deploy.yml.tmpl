# Build and deploy the generated hotato webhook worker ({{STACK}}).
# Fill in the deploy step for your platform; the build + contract test are ready.
name: deploy-hotato-webhook

on:
  push:
    branches: [main]
  workflow_dispatch:

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - name: Install
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt pytest pyyaml
      - name: Contract test (the four honesty invariants)
        run: pytest -q tests/test_webhook_contract.py

  deploy:
    needs: test
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Build image
        run: docker build -t hotato-webhook-{{STACK}} .
      # Add your platform's deploy step here (Cloud Run, Fly, Railway, ECS, ...).
      # The image serves app:app on $PORT; point your {{STACK_TITLE}} webhook at
      # POST /webhook and set the secrets from .env.example.
      - name: Deploy
        run: echo "add your deploy step (see README.md)"
