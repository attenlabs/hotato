        "name": "lookup_account"
      }
    ],
    "rubric": []
  },
  "inconclusive_policy": "refuse",
  "success": {
    "required": ["all_deterministic_assertions_pass", "no_inconclusive"],
    "report_dimensions": ["outcome", "policy", "conversation", "speech", "reliability"]
  }
}
