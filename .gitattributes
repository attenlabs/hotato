# Line-ending policy for the BYTE-ORACLE files.
#
# A default Windows checkout (core.autocrlf=true) rewrites text files to CRLF.
# For most files that is harmless, but two kinds of file are a byte oracle and
# MUST stay LF on every platform, or an untouched, correct checkout starts
# failing:
#
#   * the digest-pinned Failure Record reference kit -- its evidence sha256s
#     are taken over the raw file bytes, so an added \r changes every digest
#     and the conformance oracle rejects an untampered kit; and
#   * the shell scripts -- `bash -n` and a real shell choke on a trailing \r.
#
# `eol=lf` forces these to check out with LF regardless of the local
# autocrlf/eol setting.

# Shell scripts: keep LF so `bash -n` and execution work after a CRLF checkout.
*.sh text eol=lf

# The digest-pinned Failure Record reference conformance kit (record + the
# evidence files its sha256s are computed over).
tests/data/failure-record-reference/** text eol=lf

# The rendered Failure Record goldens are byte-compared in tests; pin them too.
tests/golden/failure_record/** text eol=lf

# --- GitHub Linguist: language-statistics accuracy ---------------------------
# hotato is a Python + TypeScript SDK. A few large HTML files are committed for
# convenience but are rendered build output (sample/demo failure reports) or
# presentation assets (social-preview cards), not source code. Exclude them so
# the repository language bar reflects the actual codebase instead of reading as
# an HTML project.
corpus/**/*.html        linguist-generated=true
docs/assets/*.html      linguist-generated=true
tests/golden/**/*.html  linguist-generated=true
*sample-report.html     linguist-generated=true
*-report.html           linguist-generated=true
.github/*.html          linguist-documentation=true

# Language statistics: rendered report HTML, banner/social-card sources, and
# the generated llms-full.txt are build artifacts, not source. Marking them
# linguist-generated keeps the repository's language identity (Python) honest
# on GitHub and for automated scanners.
*.html linguist-generated=true
llms-full.txt linguist-generated=true
README.pypi.md linguist-generated=true
