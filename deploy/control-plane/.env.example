# Copy to .env. Tags make local evaluation convenient; production bootstrap
# refuses them unless each external reference is replaced by an immutable
# @sha256 digest. The locally built Hotato image is tracked separately; see README.
LIVEKIT_SERVER_IMAGE=livekit/livekit-server:v1.13.1
LIVEKIT_SIP_IMAGE=livekit/sip:latest
VALKEY_IMAGE=valkey/valkey:8-alpine
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.153.0

# Generate values with a cryptographic password generator. Never commit .env.
LIVEKIT_API_KEY=replace-with-api-key
LIVEKIT_API_SECRET=replace-with-at-least-32-random-characters
HOTATO_PRODUCTION_TOKEN=replace-with-at-least-32-random-characters
VALKEY_PASSWORD=replace_with_at_least_32_urlsafe_chars

# Public/NAT address advertised by LiveKit's media service on a Linux host.
# Use "auto" for LiveKit's documented STUN discovery path. For loopback-only
# testing, use 127.0.0.1 and do not expose firewall ports. LiveKit SIP uses its
# documented use_external_ip discovery path.
MEDIA_NODE_IP=127.0.0.1

# Automatic session finalization, persisted alert evaluation, and retention.
# "none" disables deletion. A numeric value is an explicit local retention
# window in days; upstream collectors and backups need their own policy.
HOTATO_MAINTENANCE_INTERVAL_SECONDS=30
HOTATO_QUIESCENCE_SECONDS=30
HOTATO_REQUIRED_LANES=participant_audio,transcript,model_trace,tool_calls,backend_state
HOTATO_RETENTION_DAYS=30
