# hotato self-host — optional environment for docker compose.
# Copy to deploy/hotato.env and edit. Every value here is OPTIONAL.
#
#   cp deploy/hotato.env.example deploy/hotato.env
#
# deploy/hotato.env is git-ignored by convention (it may hold a token). Keep it
# owner-readable only:  chmod 0600 deploy/hotato.env

# --- Workspace bearer token --------------------------------------------------
# If unset, the server GENERATES a token on first start and stores it 0600 at
# /data/serve/default/token; read it with:
#   docker compose exec hotato-workspace cat /data/serve/default/token
# Set it here to pin a known token (it is written to a 0600 file in-container and
# passed as --token-file, never placed on the process command line). For the
# strongest handling, use a Docker secret instead (docs/SELF-HOST.md § Token).
# HOTATO_SERVE_TOKEN=

# --- Local judge model (only used with the `judge` profile) ------------------
# The default judge model name the in-container CLI uses for `rubric`/`test`
# runs against the Ollama service. Pull it once:  ollama pull <model>
# HOTATO_JUDGE_MODEL=llama3.1:8b
