{
  "agent": "reference-agent-v1",
  "assertions": {
    "deterministic": [
      {
        "dimension": "conversation",
        "id": "caller-stated-need",
        "kind": "phrase",
        "regex": "hi,",
        "role": "caller"
      },
      {
        "count": {
          "min": 1
        },
        "dimension": "conversation",
        "id": "caller-turns",
        "kind": "count",
        "phrase": "\\S",
        "role": "caller"
      },
      {
        "dimension": "outcome",
        "id": "outcome-tool",
        "kind": "tool_result",
        "name": "book_appointment",
        "result_subset": {
          "status": "confirmed"
        }
      },
      {
        "dimension": "outcome",
        "expect": {
          "status": "confirmed"
        },
        "filters": {
          "appointment_id": "appt_900"
        },
        "id": "outcome-state",
        "kind": "state",
        "resource": "appointments"
      },
      {
        "dimension": "policy",
        "id": "identity-before-action",
        "kind": "sequence",
        "steps": [
          {
            "tool": "verify_identity"
          },
          {
            "tool": "book_appointment"
          }
        ]
      },
      {
        "dimension": "speech",
        "id": "tool-latency",
        "kind": "latency",
        "max_ms": 1500,
        "tool": "book_appointment"
      }
    ]
  },
  "id": "appointment-book-basic-test",
  "kind": "hotato.conversation-test",
  "repetitions": 1,
  "scenario": "../scenarios/appointment-book-basic.scenario.json",
  "success": {
    "report_dimensions": [
      "outcome",
      "policy",
      "conversation",
      "speech"
    ],
    "required": [
      "all_deterministic_assertions_pass"
    ]
  },
  "version": 1
}
