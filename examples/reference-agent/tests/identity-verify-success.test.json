{
  "agent": "reference-agent-v1",
  "assertions": {
    "deterministic": [
      {
        "dimension": "conversation",
        "id": "caller-stated-need",
        "kind": "phrase",
        "regex": "i'm",
        "role": "caller"
      },
      {
        "count": {
          "min": 1
        },
        "dimension": "conversation",
        "id": "caller-turns",
        "kind": "count",
        "phrase": "\\S",
        "role": "caller"
      },
      {
        "dimension": "outcome",
        "id": "outcome-tool",
        "kind": "tool_result",
        "name": "verify_identity",
        "result_subset": {
          "verified": true
        }
      },
      {
        "dimension": "outcome",
        "expect": {
          "authenticated": true
        },
        "filters": {
          "patient_id": "patient_500"
        },
        "id": "outcome-state",
        "kind": "state",
        "resource": "sessions"
      },
      {
        "dimension": "speech",
        "id": "tool-latency",
        "kind": "latency",
        "max_ms": 1500,
        "tool": "verify_identity"
      }
    ]
  },
  "id": "identity-verify-success-test",
  "kind": "hotato.conversation-test",
  "repetitions": 1,
  "scenario": "../scenarios/identity-verify-success.scenario.json",
  "success": {
    "report_dimensions": [
      "outcome",
      "policy",
      "conversation",
      "speech"
    ],
    "required": [
      "all_deterministic_assertions_pass"
    ]
  },
  "version": 1
}
