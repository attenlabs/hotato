# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# Build / packaging artifacts
dist/
build/
*.egg-info/
.eggs/
wheels/

# Editor / OS cruft
.DS_Store
*.orig
*.bak
*.swp

# Local scratch / coverage
.coverage
htmlcov/
.tox/

# -----------------------------------------------------------------------------
# DO NOT ignore the bundled reference audio.
#
# The synthetic reference WAVs under src/hotato/data/ ship *inside*
# the package (see [tool.setuptools.package-data] in pyproject.toml). They are
# the runnable floor for the eval and MUST be committed and distributed. Keep
# any broad "*.wav" ignore rules OUT of this file, or add an explicit unignore
# like the one below if a parent .gitignore ever starts excluding audio.
# -----------------------------------------------------------------------------
!src/hotato/data/**/*.wav
!src/hotato/data/**/*.json

# --- internal / not for the public repo (curated 2026-07-05) ---
HANDOFF-*.md
benchmark-report/
# rendered suite audio regenerates byte-identically in ~19s: python3 corpus/suites/build_suites.py
corpus/suites/*/audio/
# rendered class-corpus audio regenerates byte-identically: python3 corpus/classes/build_classes.py
corpus/classes/*/audio/

# reference-agent runtime output (regenerates via `make reference`)
examples/reference-agent/.workspace/
examples/reference-agent/.out/

# Voice Failure Atlas (delta D5): scripts/build_atlas.py renders atlas/*
# typed sources into this static site, deterministically. Never committed.
_atlas_site/

# local QA/scratch artifacts
.hotato/
hotato-output/
hotato-analyze*.html
hotato-fixplan*.json
hotato-pull-*/
hotato-sweep-*/
dist_101/
hotato-review.html
*.review.html

# Claude Code local working dir (agent worktrees, session config) -- never publish
.claude/
.audit/

# Internal build/dev notes -- never publish
implementation-notes/

# TypeScript SDK (sdk/typescript): local install + build output
sdk/typescript/node_modules/
sdk/typescript/dist/

# local dev venv used to run the CLI under the SDK test suite
# (python3 -m venv .v && .v/bin/pip install -e .)
.v/

# `hotato start --demo` output, when run from the repo root (matches the
# literal names in src/hotato/start.py: _SWEEP_JSON/_SWEEP_HTML/_FUNNEL_CARD/
# _CONTRACTS_DIR/_DEMO_RECORD_DIR)
hotato-sweep.json
hotato-sweep.html
hotato-no-single-threshold.svg
hotato-failure-record/
/contracts/

# Internal SAA artifacts: crown-jewel, never public. Kept out of the public
# repo durably (not just via local .git/info/exclude). Do not remove.
docs/SAA-BEHAVIOR-CARD.md
docs/SAA-FIX-POINTER.md
docs/saa_behavior_card.py
tests/test_saa_card.py

# hotato start writes its demo saydo/ output to CWD; ignore it at repo root
/saydo/
