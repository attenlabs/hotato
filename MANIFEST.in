include README.md LICENSE SECURITY.md CHANGELOG.md CONTRIBUTING.md METHODOLOGY.md llms.txt llms-full.txt sync_engine.py server.json CITATION.cff
# The root composite GitHub Action: the shipped tests
# (tests/test_action_consumer.py) parse and pin-check it, so the sdist must
# carry it or the sdist-guard reddens on a file the checkout always has.
include action.yml
recursive-include docs *
prune docs/assets
# The open wire-format spec (spec/README.md, spec/contract.schema.json,
# spec/CANONICALIZATION.md): tests/test_bench_cli.py pins the spec schema
# byte-identical to the shipped one, so the sdist must carry both.
recursive-include spec *
recursive-include adapters *
recursive-include scripts *
recursive-include tests *
recursive-include ci *
recursive-include .github *
exclude .github/banner.png

# The `hotato init webhook` templates ship in the wheel (package-data) and the
# sdist (here); they are rendered per stack into a generated worker project.
recursive-include src/hotato/templates *.tmpl *.py

# The claim-language contract (scripts/copy_lint.py + card.py read it at run
# time) ships in the wheel (package-data) and the sdist (here).
include src/hotato/py.typed
include src/hotato/data/evidence_language.json
# The starter per-model price table for `hotato observe cost --prices starter`
# ships in the wheel (package-data) and the sdist (here).
include src/hotato/data/prices.yaml

# The curated, seeded persona/scenario pack (hotato.simulate_pack) ships in the
# wheel (package-data) and the sdist (here): the manifest, each scenario.v1 the
# deterministic caller renders, and the pack README.
recursive-include src/hotato/data/simulate/pack *.json *.md

# The curated, deterministic assertion packs (hotato.assert_packs) ship in the
# wheel (package-data) and the sdist (here): the manifest + each assert.v1 pack
# file merged into a run with `hotato assert run --pack`.
recursive-include src/hotato/data/assertions/packs *.json

# The bundled turn-taking gauntlet suite (hotato.gauntlet) ships in the wheel
# (package-data) and the sdist (here): the manifest of standardized stress cases
# `hotato gauntlet` scores over the packaged reference audio.
recursive-include src/hotato/data/gauntlet *.json

# The bundled Silero VAD ONNX weights (~2.33 MB, MIT) for the OPTIONAL [neural]
# extra ship in the wheel (package-data) and the sdist (here). Unlike the
# deterministic *.wav fixtures (regenerated by conftest), this model file cannot
# be reconstructed, so it MUST be carried in the source distribution. Its MIT
# attribution notice ships alongside it.
include src/hotato/data/silero_vad.onnx
include src/hotato/data/silero_vad.onnx.NOTICE
include NOTICE

# Self-host deployment bundle: the Dockerfile, compose file, and deploy/
# helpers are part of the source distribution the same way docs/, ci/, and
# .github/ are -- the sdist is a full-repo mirror, and the shipped
# tests/test_selfhost_config.py asserts these files exist and lint clean so a
# broken container config fails the sdist-guard, not a customer's VPC. Without
# these the extracted sdist has tests/ but not the files those tests check.
include Dockerfile docker-compose.yml .dockerignore
recursive-include deploy *

# Corpus and examples: ship the SMALL, non-audio test dependencies so the
# shipped test suite collects and runs from an extracted sdist, while keeping
# the heavy real and rendered audio pruned. The extension filters below match
# scenario labels, manifests, validators, and the deterministic builders, and
# never match *.wav, so no heavy audio is carried. Suite and class audio is
# regenerated deterministically by tests/conftest.py (seed = sha256(id)) when
# absent; tests that need genuinely-absent heavy real audio skip cleanly.
recursive-include corpus *.json *.py *.md *.html
recursive-include examples *.json *.py *.md *.sh *.yaml

# Generated-at-run-time output (gitignored, regenerates on demand) that the
# include filters above would otherwise sweep up from a working tree where
# tests or the reference agent have run -- the 1.6.1/1.6.2 sdists shipped
# 1,151 files under examples/reference-agent/.out/ this way. MANIFEST.in
# reads the working tree, not git, so these prunes are only the belt: the
# canonical release build (scripts/build_release.py) exports `git archive
# HEAD` into a fresh directory, and the tag-faithfulness test in
# tests/test_release_supply_chain.py asserts every sdist member is a
# git-tracked path. Generated corpus renders that land NEXT TO tracked files
# in corpus/suites/ and corpus/classes/ cannot be pattern-separated here at
# all; only that clean-tree build path keeps them out.
prune examples/reference-agent/.out
prune examples/reference-agent/.workspace
prune corpus/suites/*/audio
prune corpus/classes/*/audio
# the schema example's small stereo wav is the validator's PASS fixture, not
# heavy audio (~0.4 MB); ship it so test_corpus_validate has its example.
include corpus/examples/sample-contribution.example.wav

# Voice Failure Atlas (delta D5) typed sources: tests/test_atlas.py loads
# every atlas/{records,contracts,implementations}/*.json directly, so the
# sdist needs them the same way it needs corpus/ and examples/ above.
recursive-include atlas *.json

global-exclude __pycache__ *.py[cod]
